{
  "name": "windautomatex",
  "version": "1.0.0",
  "description": "Windows Desktop Automation Application",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build && concurrently \"npm run build:main:watch\" \"npm run build:renderer:watch\" \"electron .\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.config.js --env target=main",
    "build:main:watch": "webpack --config webpack.config.js --env target=main --watch",
    "build:renderer": "webpack --config webpack.config.js --env target=renderer",
    "build:renderer:watch": "webpack --config webpack.config.js --env target=renderer --watch",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "automation",
    "windows",
    "electron"
  ],
  "author": "WindAutomateX",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "crypto-js": "^4.2.0",
    "electron": "39.8.1",
    "node-cron": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.2",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  }
}
